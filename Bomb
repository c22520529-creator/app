<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>拆炸彈 💣</title>
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;700;800&family=Noto+Sans+TC:wght@400;700;900&display=swap" rel="stylesheet">
<style>
:root{--ink:#6b4a32;--ink-soft:#b79c85;--paper:#fdf6ea;--card:#fffdf8;
  --line:#f0e2cd;--todo:#e8a54f;--green:#8aa96a;--blue:#7fa8dd;--red:#d97b6c;}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:"Noto Sans TC",sans-serif;color:var(--ink);background:var(--paper);
  -webkit-tap-highlight-color:transparent;padding:14px;user-select:none;-webkit-user-select:none;}
button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit;}
.wrap{max-width:520px;margin:0 auto;}
.top{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
.title{font-size:1.15rem;font-weight:900;}
.back{background:var(--card);border:1.5px solid var(--line);border-radius:99px;
  padding:7px 14px;font-size:.8rem;font-weight:700;}

.setup{background:var(--card);border:1.5px solid var(--line);border-radius:18px;padding:20px;text-align:center;}
.setup h2{font-size:1.1rem;margin-bottom:8px;}
.rule{font-size:.87rem;line-height:2;text-align:left;background:var(--paper);
  border-radius:14px;padding:14px;margin:12px 0;}
.go{width:100%;background:var(--todo);color:#fff;padding:14px;border-radius:14px;font-weight:900;font-size:1rem;}
.go:active{transform:scale(.98);}

.game{display:none;}
.game.show{display:block;}
.turnbar{display:flex;gap:8px;margin-bottom:12px;}
.pl{flex:1;background:var(--card);border:2px solid var(--line);border-radius:14px;
  padding:9px;display:flex;align-items:center;gap:8px;transition:.15s;}
.pl.now{border-color:var(--todo);background:#fceedb;}
.pl img{width:34px;flex-shrink:0;}
.pl .n{font-weight:800;font-size:.86rem;}

.bombbox{background:var(--card);border:1.5px solid var(--line);border-radius:18px;
  padding:16px;text-align:center;margin-bottom:12px;}
.bombcount{font-size:.85rem;color:var(--ink-soft);font-weight:800;margin-bottom:10px;}
.seeds{display:flex;flex-wrap:wrap;gap:6px;justify-content:center;min-height:110px;align-items:center;}
.seed{font-size:1.7rem;transition:.2s;}
.seed.gone{opacity:0;transform:scale(0) rotate(180deg);width:0;font-size:0;}
.bomb{font-size:3.2rem;animation:tick 1s ease-in-out infinite;}
@keyframes tick{0%,100%{transform:rotate(-5deg) scale(1);}50%{transform:rotate(5deg) scale(1.07);}}
.boom{font-size:4rem;animation:boomA .6s ease;}
@keyframes boomA{0%{transform:scale(.3);}60%{transform:scale(1.4);}100%{transform:scale(1);}}

.pick{display:flex;gap:9px;}
.pick button{flex:1;background:var(--card);border:2px solid var(--line);border-radius:16px;
  padding:16px 0;font-weight:900;font-size:1.1rem;transition:.15s;}
.pick button:active{transform:scale(.95);border-color:var(--todo);background:#fceedb;}
.pick button:disabled{opacity:.35;}
.hint{text-align:center;font-size:.82rem;color:var(--ink-soft);font-weight:700;margin-top:10px;min-height:1.3em;}

.over{position:fixed;inset:0;background:rgba(107,74,50,.5);display:none;
  align-items:center;justify-content:center;padding:24px;z-index:80;}
.over.show{display:flex;}
.over .box{background:var(--card);border-radius:22px;padding:26px 22px;text-align:center;max-width:320px;width:100%;}
.over img{width:96px;margin:0 auto 8px;display:block;}
.over .t{font-size:1.25rem;font-weight:900;margin-bottom:6px;}
.over .s{font-size:.88rem;color:var(--ink-soft);font-weight:700;margin-bottom:16px;line-height:1.6;}
.over button{width:100%;padding:13px;border-radius:14px;font-weight:800;margin-top:8px;}
.over .again{background:var(--todo);color:#fff;}
.over .home{background:var(--paper);border:1.5px solid var(--line);color:var(--ink);}
</style>
</head>
<body>
<div class="wrap">
  <div class="top">
    <div class="title">💣 拆炸彈</div>
    <button class="back" id="backBtn">← 回去</button>
  </div>

  <div class="setup" id="setup">
    <h2>怎麼玩？</h2>
    <div class="rule">
      🌰 桌上有 <b>21 顆瓜子</b><br>
      🔄 兩個人<b>輪流</b>拿走 <b>1～3 顆</b><br>
      💣 拿到<b>最後一顆</b>的人就<b>炸掉了</b>！<br>
      🧠 要想清楚喔，這個可以算的 😏
    </div>
    <button class="go" id="startBtn">開始玩</button>
  </div>

  <div class="game" id="game">
    <div class="turnbar">
      <div class="pl" id="plA"><img id="imgA" src=""><span class="n">玩家1</span></div>
      <div class="pl" id="plB"><img id="imgB" src=""><span class="n">玩家2</span></div>
    </div>

    <div class="bombbox">
      <div class="bombcount" id="cnt">還有 21 顆</div>
      <div class="seeds" id="seeds"></div>
    </div>

    <div class="pick">
      <button data-n="1">拿 1 顆</button>
      <button data-n="2">拿 2 顆</button>
      <button data-n="3">拿 3 顆</button>
    </div>
    <div class="hint" id="hint">輪到 玩家1，要拿幾顆？</div>
  </div>
</div>

<div class="over" id="over">
  <div class="box">
    <img id="overImg" src="">
    <div class="t" id="overT"></div>
    <div class="s" id="overS"></div>
    <button class="again" id="againBtn">🔄 再玩一次</button>
    <button class="home" id="homeBtn">← 回 APP</button>
  </div>
</div>

<script>
const IMG_A = "data:image/webp;base64,", IMG_B = "data:image/webp;base64,";
const START = 21;
const $ = id => document.getElementById(id);
let left = START, turn = 0, busy = false;
const sleep = ms => new Promise(r=>setTimeout(r,ms));

$("imgA").src = IMG_A; $("imgB").src = IMG_B;

$("startBtn").onclick = () => {
  $("setup").style.display = "none";
  $("game").classList.add("show");
  reset();
};
function reset(){
  left = START; turn = 0; busy = false;
  drawSeeds(); updateUI();
  $("over").classList.remove("show");
}
function drawSeeds(){
  const el = $("seeds");
  el.innerHTML = "";
  for(let i=0;i<left;i++){
    const s = document.createElement("span");
    s.className = "seed"; s.textContent = "🌰";
    el.appendChild(s);
  }
  if(left === 1){
    el.innerHTML = '<span class="bomb">💣</span>';
  }
}
function updateUI(){
  $("cnt").textContent = left === 1 ? "只剩最後一顆… 是炸彈！💣" : `還有 ${left} 顆`;
  $("plA").className = "pl" + (turn===0?" now":"");
  $("plB").className = "pl" + (turn===1?" now":"");
  $("hint").textContent = `輪到 玩家${turn+1}，要拿幾顆？`;
  document.querySelectorAll(".pick button").forEach(b=>{
    b.disabled = busy || (+b.dataset.n > left);
  });
}

document.querySelectorAll(".pick button").forEach(btn=>{
  btn.onclick = async () => {
    if(busy) return;
    const n = +btn.dataset.n;
    if(n > left) return;
    busy = true;
    updateUI();

    // 一顆一顆消失
    const seeds = [...$("seeds").querySelectorAll(".seed")];
    for(let i=0;i<n;i++){
      const s = seeds[seeds.length-1-i];
      if(s) s.classList.add("gone");
      await sleep(160);
    }
    left -= n;
    $("hint").textContent = `玩家${turn+1} 拿走 ${n} 顆`;
    await sleep(350);

    if(left <= 0){
      // 拿到最後一顆 → 自己炸掉
      $("seeds").innerHTML = '<span class="boom">💥</span>';
      $("cnt").textContent = "轟——！";
      await sleep(900);
      finish(turn);
      return;
    }
    turn = 1 - turn;
    drawSeeds(); busy = false; updateUI();
  };
});

function finish(loser){
  const winner = 1 - loser;
  $("overImg").src = winner === 0 ? IMG_A : IMG_B;
  $("overT").textContent = `玩家${winner+1} 贏了！🎉`;
  $("overS").textContent = `玩家${loser+1} 拿到最後一顆，💥 炸掉了！`;
  $("over").classList.add("show");
}
$("againBtn").onclick = reset;
$("homeBtn").onclick = () => location.href = "index.html";
$("backBtn").onclick = () => { if(document.referrer) history.back(); else location.href = "index.html"; };
</script>
</body>
</html>
